# THIS FILE IS FOR DOCUMENTATION ONLY - DO NOT ADD REAL VALUES
# The actual Secret is created imperatively and never committed to git.
# To recreate the Secret after a cluster reset, run:
#
# kubectl create secret generic kk-payments-secrets \
#   --from-literal=DB_PASSWORD=<obtain from team lead> \
#   --from-literal=STRIPE_API_KEY=<obtain from team lead> \
#   --from-literal=JWT_SECRET=<obtain from team lead> \
#   -n kijani-project
#
apiVersion: v1
kind: Secret
metadata:
  name: kk-payments-secrets
  namespace: kijani-project
type: Opaque
data:
  DB_PASSWORD: <base64-encoded-value>
  STRIPE_API_KEY: <base64-encoded-value>
  JWT_SECRET: <base64-encoded-value>
